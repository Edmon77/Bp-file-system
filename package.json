{
  "name": "bp-file-system",
  "version": "0.0.0",
  "private": true,
  "author": "",
  "description": "",
  "license": "UNLICENSED",
  "scripts": {
    "db:push": "turbo run db:push",
    "db:generate": "turbo run db:generate",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.ts\" \"**/*.js\" \"**/*.json\""
  },
